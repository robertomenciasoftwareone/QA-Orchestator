# ─── JIRA ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=ESXTRA

# ─── CONFLUENCE ───────────────────────────────────────────────────────────────
# Usually same base URL as Jira for Cloud
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your_jira_api_token_here  # Same token as Jira for Atlassian Cloud

# ─── FIGMA ────────────────────────────────────────────────────────────────────
FIGMA_TOKEN=figd_your_figma_personal_access_token

# ─── ZEPHYR SCALE ─────────────────────────────────────────────────────────────
# Zephyr Scale API token (separate from Jira token)
# Get it at: Jira → Apps → Zephyr Scale → API Access Tokens
ZEPHYR_API_TOKEN=your_zephyr_scale_api_token
ZEPHYR_ACCOUNT_ID=your_atlassian_account_id
